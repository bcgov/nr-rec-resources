# Keycloak (OIDC) configuration
VITE_KEYCLOAK_AUTH_SERVER_URL=<auth-url>
VITE_KEYCLOAK_REALM=standard
VITE_KEYCLOAK_CLIENT_ID=<client-id>
BACKEND_URL=<admin-backend-url>
VITE_RECREATION_RESOURCE_ASSETS_BASE_URL=<assets-url>
VITE_STAFF_ADMIN_URL=<act-tool-url>
HAPPO_API_KEY=
HAPPO_API_SECRET=
HAPPO_PROJECT=rst-admin

# E2E test credentials (local docker-compose: use e2e-admin / e2e-viewer from realm-export)
E2E_BASE_URL=http://localhost:3001
E2E_ADMIN_USERNAME=e2e-admin
E2E_ADMIN_PASSWORD=TestPass1!
E2E_VIEWER_USERNAME=e2e-viewer
E2E_VIEWER_PASSWORD=TestPass1!
