KEYCLOAK_AUTH_SERVER_URL=https://<keycloak-url>
KEYCLOAK_REALM=<realm>>
KEYCLOAK_ISSUER=https://<keycloak-url>/realms/standard
KEYCLOAK_CLIENT_ID=<client-id>
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=postgres
POSTGRES_SCHEMA=rst
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}/${POSTGRES_DATABASE}?schema=${POSTGRES_SCHEMA}
AWS_EMF_ENVIRONMENT=Local
APP_ENV=local
ESTABLISHMENT_ORDER_DOCS_BUCKET=rst-lza-establishment-order-docs-dev
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Recreation Resource Assets S3 Buckets
RST_STORAGE_IMAGES_BUCKET=rst-storage-images-dev
RST_STORAGE_PUBLIC_DOCUMENTS_BUCKET=rst-storage-public-documents-dev
RST_STORAGE_CONSENT_FORMS_BUCKET=rst-storage-consent-forms-dev
